# Supabase（サーバー側のみ。NEXT_PUBLIC_ を付けないこと — ブラウザには渡さない）
# SUPABASE_SECRET_KEY は新方式の secret key（sb_secret_...）。旧 service_role キーの後継
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Claude API（AI機能実装時に使用）
ANTHROPIC_API_KEY=

# リマインダー配信cronの認証トークン（ランダムな長い文字列を設定）
CRON_SECRET=

# Web Push（VAPID鍵ペア。npx web-push generate-vapid-keys で生成）
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# 「今日」の境界判定に使うタイムゾーン
APP_TIMEZONE=Asia/Tokyo
